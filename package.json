{
  "name": "vuln-scope",
  "version": "0.1.0",
  "description": "Detect whether your code is actually affected by known vulnerabilities, not just your dependency tree.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@11.1.3",
  "bin": {
    "vuln-scope": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "ci": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test",
    "audit:strict": "pnpm audit --audit-level=moderate",
    "prepublishOnly": "pnpm run ci && pnpm run build"
  },
  "dependencies": {
    "commander": "14.0.3",
    "ts-morph": "28.0.0",
    "typescript": "6.0.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.0",
    "eslint": "10.4.0",
    "prettier": "3.8.3",
    "tsx": "4.22.2",
    "typescript-eslint": "8.59.4",
    "vitest": "4.1.6"
  },
  "license": "MIT"
}
